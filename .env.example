# Vyst Open Auth — Example Configuration
# Copy this file to .env.development and fill in your values.
# Never commit real credentials to version control.

# Server
PORT=8080
GRPC_PORT=50051

# Database (PostgreSQL)
# Use the 'vyst_app' restricted role for runtime. Use 'postgres' superuser only for migrations.
DATABASE_URL=postgres://vyst_app:STRONG_PASSWORD_HERE@localhost:5432/vyst_identity?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Keys — generate with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Then paste the contents below (preserve newlines using \n or use a multi-line env block).
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# CAPTCHA (Cloudflare Turnstile)
# Leave empty to disable CAPTCHA in local development.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# TOTP
TOTP_ISSUER=Vyst Identity

# WebAuthn
# In production: WEBAUTHN_RP_ID must be your actual domain, WEBAUTHN_ORIGIN must be HTTPS.
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000
WEBAUTHN_RP_NAME=Vyst Identity

# Frontend URL (used in email links for password reset and email verification)
FRONTEND_URL=http://localhost:4200

# Observability
ENABLE_TELEMETRY=true
# OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317

# Notification (Email via SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@example.com
SMTP_PASS=YOUR_SMTP_PASSWORD_HERE

# SMS via Plivo (optional)
PLIVO_AUTH_ID=YOUR_PLIVO_AUTH_ID_HERE
PLIVO_AUTH_TOKEN=YOUR_PLIVO_AUTH_TOKEN_HERE

# External APIs
BRASIL_API_URL=https://brasilapi.com.br/api/cnpj/v1
SERPRO_API_URL=
SERPRO_API_KEY=
